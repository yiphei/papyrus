# Copy to .env and fill in. .env is gitignored.

# Required: your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Required: your Tavily API key (https://tavily.com)
TAVILY_API_KEY=

# Optional overrides
# PAPYRUS_LLM_MODEL=claude-sonnet-4-6
# PAPYRUS_CACHE_TTL_S=900

# Frontend (Vite reads VITE_* at build time)
VITE_MAPBOX_TOKEN=
# Backend URL the frontend talks to
VITE_API_URL=http://127.0.0.1:8000
